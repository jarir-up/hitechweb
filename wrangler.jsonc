{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hitechprinters",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "hitechprinters.com.pk", "custom_domain": true },
    { "pattern": "www.hitechprinters.com.pk", "custom_domain": true }
  ]
}
